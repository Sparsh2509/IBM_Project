# =============================================================================
# .dockerignore — Controls what is sent to the Docker build context.
# A smaller build context = faster builds and smaller images.
# Most importantly: .env must NEVER be included in the image.
# =============================================================================

# --- Secrets (CRITICAL: never bake API keys into the image) ---
.env
*.env
.env.*

# --- Version control ---
.git
.gitignore
.gitattributes

# --- Python bytecode & caches ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# --- Virtual environments ---
venv/
.venv/
env/
ENV/
.venv/
virtualenv/

# --- IDE & editor files ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Development & testing artifacts ---
*.log
*.tmp
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# --- Documentation (not needed at runtime) ---
README.md
*.md
docs/

# --- Jupyter notebooks ---
*.ipynb
.ipynb_checkpoints/

# --- Unused CLI entry point (app.py is a terminal script, not needed in Docker) ---
# app.py   ← Kept commented out: we copy it anyway for completeness

# --- Model list utility (not used at runtime) ---
model_list.py

# --- Streamlit local secrets (we use env vars instead) ---
.streamlit/secrets.toml
